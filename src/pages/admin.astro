---
// Admin dashboard — only accessible to users with tier='admin'.
// Shows user list, usage stats, tier management, cost estimates.
import { supabaseAdmin } from '../lib/supabase.js';

const { locals } = Astro;
const user = locals.user;
const profile = locals.profile;

// Gate: must be admin
if (!user || !profile || profile.tier !== 'admin') {
  return Astro.redirect('/');
}

if (!supabaseAdmin) {
  return new Response('Admin client not configured', { status: 500 });
}

// Fetch all data for the dashboard
const { data: allProfiles } = await supabaseAdmin
  .from('profiles')
  .select('id, display_name, household_id, experience, tier, beta_tester, onboarded, created_at');

const { data: allUsage } = await supabaseAdmin
  .from('user_usage')
  .select('user_id, month, count');

// User messages (suggestions, deletion reasons, etc.)
const { data: allMessages } = await supabaseAdmin
  .from('user_messages')
  .select('*')
  .order('created_at', { ascending: false })
  .limit(100);
const messages = allMessages || [];
const unreadCount = messages.filter(m => !m.read).length;

const { data: allUsers } = await supabaseAdmin.auth.admin.listUsers();
const users = allUsers?.users || [];

const { data: allBookmarks } = await supabaseAdmin
  .from('bookmarks')
  .select('id', { count: 'exact', head: true });

const { data: allHouseholds } = await supabaseAdmin
  .from('households')
  .select('id', { count: 'exact', head: true });

// Activity log (recent 200 entries from beta testers)
const { data: activityData } = await supabaseAdmin
  .from('activity_log')
  .select('*')
  .order('created_at', { ascending: false })
  .limit(200);
const activityLog = activityData || [];

// Build stats
const currentMonth = new Date().toISOString().slice(0, 7);
const profiles = allProfiles || [];
const usageRows = allUsage || [];

const totalUsers = profiles.length;
const subscribers = profiles.filter(p => p.tier === 'subscriber').length;
const friends = profiles.filter(p => p.tier === 'friend').length;
const freeUsers = profiles.filter(p => p.tier === 'free').length;

const thisMonthUsage = usageRows.filter(u => u.month === currentMonth);
const totalGenerationsThisMonth = thisMonthUsage.reduce((sum, u) => sum + u.count, 0);
const estimatedCostThisMonth = (totalGenerationsThisMonth * 0.005).toFixed(2);

// Per-user table: merge profiles + auth users + usage
const userTable = profiles.map(p => {
  const authUser = users.find(u => u.id === p.id);
  const monthUsage = thisMonthUsage.find(u => u.user_id === p.id);
  const totalUsage = usageRows.filter(u => u.user_id === p.id).reduce((sum, u) => sum + u.count, 0);
  return {
    id: p.id,
    email: authUser?.email || '?',
    display_name: p.display_name || '-',
    tier: p.tier,
    beta_tester: p.beta_tester || false,
    experience: p.experience,
    this_month: monthUsage?.count || 0,
    total: totalUsage,
    est_cost: (totalUsage * 0.005).toFixed(2),
    created: new Date(p.created_at).toLocaleDateString(),
    cost_flag: totalUsage * 0.005 > 10,
  };
}).sort((a, b) => b.total - a.total);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Recipe Wizard Pro</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header>
    <div class="header-left">
      <a href="/" style="text-decoration:none"><h1>&#129668; Recipe Wizard Admin</h1></a>
    </div>
    <nav class="header-nav">
      <a href="/" class="tab-switch-btn">Back to chat</a>
    </nav>
  </header>

  <div class="settings-page">
    <!-- Summary cards -->
    <div class="admin-summary">
      <div class="admin-stat">
        <span class="admin-stat-number">{totalUsers}</span>
        <span class="admin-stat-label">Total users</span>
      </div>
      <div class="admin-stat">
        <span class="admin-stat-number">{subscribers}</span>
        <span class="admin-stat-label">Subscribers</span>
      </div>
      <div class="admin-stat">
        <span class="admin-stat-number">{friends}</span>
        <span class="admin-stat-label">Friends</span>
      </div>
      <div class="admin-stat">
        <span class="admin-stat-number">{totalGenerationsThisMonth}</span>
        <span class="admin-stat-label">Generations ({currentMonth})</span>
      </div>
      <div class="admin-stat">
        <span class="admin-stat-number">${estimatedCostThisMonth}</span>
        <span class="admin-stat-label">Est. cost ({currentMonth})</span>
      </div>
    </div>

    <!-- User messages -->
    {messages.length > 0 && (
      <div class="settings-section">
        <h2>Messages {unreadCount > 0 && <span class="unread-badge">{unreadCount} new</span>}</h2>
        <div class="admin-messages">
          {messages.map(m => (
            <div class={`admin-message ${m.read ? 'read' : 'unread'}`} data-id={m.id}>
              <div class="admin-message-meta">
                <strong>{m.user_email || 'anonymous'}</strong>
                <span class="admin-message-context">{m.context}</span>
                <span class="admin-message-date">{new Date(m.created_at).toLocaleString()}</span>
                {!m.read && (
                  <button class="admin-message-markread" onclick={`markMessageRead('${m.id}')`}>Mark read</button>
                )}
              </div>
              <p class="admin-message-body">{m.message}</p>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- User table -->
    <div class="settings-section">
      <h2>Users</h2>
      <table class="admin-table">
        <thead>
          <tr>
            <th>User</th>
            <th>Tier</th>
            <th>This month</th>
            <th>All time</th>
            <th>Est. cost</th>
            <th>Joined</th>
            <th>Beta</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {userTable.map(u => (
            <tr class={u.cost_flag ? 'cost-flagged' : ''}>
              <td>
                <div>{u.display_name}</div>
                <div class="admin-email">{u.email}</div>
              </td>
              <td>
                <select class="tier-select" data-user-id={u.id} onchange={`updateTier('${u.id}', this.value)`}>
                  {['free', 'friend', 'subscriber', 'admin'].map(t => (
                    <option value={t} selected={u.tier === t}>{t}</option>
                  ))}
                </select>
              </td>
              <td>{u.this_month}</td>
              <td>{u.total}</td>
              <td class={u.cost_flag ? 'cost-warning' : ''}>${u.est_cost}{u.cost_flag && ' ⚠'}</td>
              <td>{u.created}</td>
              <td>
                <label class="beta-toggle" title="Toggle beta tester logging">
                  <input type="checkbox" checked={u.beta_tester} onchange={`toggleBeta('${u.id}', this.checked)`}>
                  <span class="beta-label">{u.beta_tester ? 'On' : 'Off'}</span>
                </label>
              </td>
              <td><span class="admin-id">{u.id.slice(0, 8)}</span></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Activity Log -->
    <div class="settings-section">
      <h2>Beta Tester Activity</h2>
      {activityLog.length === 0 ? (
        <p class="settings-hint">No activity logged yet. Enable beta tester on a user above to start logging.</p>
      ) : (
        <table class="admin-table">
          <thead>
            <tr>
              <th>User</th>
              <th>Action</th>
              <th>Detail</th>
              <th>When</th>
            </tr>
          </thead>
          <tbody>
            {activityLog.map(a => {
              const u = userTable.find(u => u.id === a.user_id);
              return (
                <tr>
                  <td>{u?.display_name || a.user_id.slice(0, 8)}</td>
                  <td><span class="activity-action">{a.action}</span></td>
                  <td class="activity-detail">{a.detail ? JSON.stringify(a.detail).slice(0, 120) : '-'}</td>
                  <td class="activity-time">{new Date(a.created_at).toLocaleString()}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      )}
    </div>
  </div>

  <script is:inline>
    window.markMessageRead = async (id) => {
      try {
        const resp = await fetch('/api/admin/message-read', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        if (resp.ok) location.reload();
      } catch {}
    };

    window.updateTier = async (userId, newTier) => {
      try {
        const resp = await fetch('/api/admin/tier', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ user_id: userId, tier: newTier }),
        });
        if (!resp.ok) alert('Failed to update tier');
      } catch { alert('Network error'); }
    };

    window.toggleBeta = async (userId, enabled) => {
      try {
        const resp = await fetch('/api/admin/beta', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ user_id: userId, beta_tester: enabled }),
        });
        if (resp.ok) {
          const label = document.querySelector(`input[onchange*="${userId}"]`)?.closest('label')?.querySelector('.beta-label');
          if (label) label.textContent = enabled ? 'On' : 'Off';
        } else {
          alert('Failed to update beta status');
        }
      } catch { alert('Network error'); }
    };
  </script>
</body>
</html>
