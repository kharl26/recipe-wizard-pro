---
// Settings page: profile, household members, invites, display name.
import { createDB } from '../lib/db.js';

const { locals } = Astro;
const user = locals.user;
const profile = locals.profile;

if (!user) return Astro.redirect('/');

const db = createDB(locals.supabase, profile);
const people = await db.getPeople();
const guests = await db.getGuests();
const allPreferences = await db.getPreferences();
const pendingInvites = await db.getPendingInvites();
const notifications = await db.getNotifications();
const household = await db.getHousehold();

// Group preferences by person/guest for display
const prefsByPerson = {};
for (const p of allPreferences) {
  const key = p.user_id || p.guest_id;
  if (!key) continue;
  if (!prefsByPerson[key]) prefsByPerson[key] = [];
  prefsByPerson[key].push(p);
}

// Registered household members (for merge-with-user dropdown)
const registeredMembers = people.filter(p => !p.is_guest);

const displayName = profile?.display_name || '';
const tier = profile?.tier || 'free';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Settings — Recipe Wizard Pro</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header>
    <div class="header-left">
      <a href="/" style="text-decoration:none"><h1>&#129668; Recipe Wizard</h1></a>
    </div>
    <nav class="header-nav">
      <a href="/" class="tab-switch-btn">Back to app</a>
    </nav>
  </header>

  <div class="settings-page">
    <!-- Notifications -->
    {notifications.filter(n => !n.read).length > 0 && (
      <div class="settings-section notifications-section">
        <h2>Notifications</h2>
        {notifications.filter(n => !n.read).map(n => (
          <div class="notification-item" data-id={n.id}>
            <strong>{n.title}</strong>
            <p>{n.body}</p>
            {n.type === 'invite' && n.metadata?.invite_id && (
              <div class="notification-actions">
                <button class="plan-btn" onclick={`respondInvite('${n.metadata.invite_id}', 'accept', '${n.id}')`}>Accept</button>
                <button class="cancel-btn" onclick={`respondInvite('${n.metadata.invite_id}', 'decline', '${n.id}')`}>Decline</button>
              </div>
            )}
          </div>
        ))}
      </div>
    )}

    <!-- Profile -->
    <div class="settings-section">
      <h2>Your Profile</h2>
      <form id="profile-form" class="settings-form">
        <label>
          Display Name
          <input type="text" name="display_name" value={displayName} placeholder="Choose a display name" maxlength="30">
        </label>
        <label>
          Cooking Experience
          <select name="experience">
            {['novice', 'beginner', 'intermediate', 'experienced', 'expert'].map(e => (
              <option value={e} selected={profile?.experience === e}>{e.charAt(0).toUpperCase() + e.slice(1)}</option>
            ))}
          </select>
        </label>
        <label class="checkbox-label">
          <input type="checkbox" name="wine_pairing" checked={profile?.wine_pairing}>
          Wine pairing suggestions
        </label>
        <button type="submit" class="plan-btn">Save profile</button>
        <span id="profile-status" class="settings-status"></span>
      </form>
    </div>

    <!-- Household -->
    <div class="settings-section">
      <h2>Household Members</h2>
      <div class="member-list">
        {people.map(p => (
          <div class="member-item">
            <div class="member-info">
              <strong>{p.name}</strong>
              <span class="member-exp">{p.experience}</span>
              {p.id === user.id && <span class="member-you">(you)</span>}
            </div>
            {p.id !== user.id && (
              <button class="cancel-btn" onclick={`removeMember('${p.id}', '${p.name}')`}>Remove</button>
            )}
          </div>
        ))}
      </div>

      {people.length === 1 && (
        <p class="settings-hint">You're cooking solo. Invite someone to share your pantry and recipes!</p>
      )}

      <h3>Invite someone</h3>
      <p class="settings-hint" style="font-size:0.82rem; margin-bottom:8px;">
        <strong>If they already have an account:</strong> they'll see a notification next time they sign in and can accept or decline. On accept, they move to your household.<br>
        <strong>If they're new:</strong> they get a magic-link email to sign up. Once they complete sign-in, they're automatically placed in your household.<br>
        In both cases, their personal preferences follow them; shared data in their old household (if any) stays behind.
      </p>
      <form id="invite-form" class="settings-form inline-form">
        <input type="email" name="email" placeholder="friend@example.com" required>
        <button type="submit" class="plan-btn">Send invite</button>
        <span id="invite-status" class="settings-status"></span>
      </form>

      {pendingInvites.length > 0 && (
        <div class="pending-invites">
          <h4>Pending invites</h4>
          {pendingInvites.map(inv => (
            <div class="invite-item">
              <span>{inv.invited_email}</span>
              <span class="invite-pending">Pending</span>
            </div>
          ))}
        </div>
      )}

      <h3>Leave household</h3>
      {people.length > 1 ? (
        <p class="settings-hint">
          Leaving creates a new personal household for you. Your preferences and saved recipes will be copied.
          <button class="cancel-btn" onclick="leaveHousehold()">Leave this household</button>
        </p>
      ) : (
        <p class="settings-hint">You're the only member — you can't leave your own household, but you can invite others to join.</p>
      )}
    </div>

    <!-- Guest members -->
    <div class="settings-section">
      <h2>Guest Household Members</h2>
      <p class="settings-hint" style="font-size:0.82rem; margin-bottom:12px;">
        People you cook for who don't have (or don't need) their own Recipe Wizard account — kids, elderly relatives, roommates. Their allergies and preferences are used when you pick them in "Cooking for" on the chat. You can later invite them to register their own account and have their profile merged in.
      </p>

      {guests.length > 0 && (
        <div class="member-list">
          {guests.map(g => (
            <div class="member-item guest-item" data-guest-id={g.id}>
              <div class="member-info" style="flex: 1;">
                <strong>{g.display_name}</strong>
                <span class="member-exp">{g.experience}</span>
                {g.wine_pairing && <span class="member-exp">🍷</span>}
                <span class="member-exp">guest</span>
              </div>
              <button class="cancel-btn" onclick={`editGuest('${g.id}', '${g.display_name.replace(/'/g, "\\'")}', '${g.experience}', ${g.wine_pairing})`} style="margin-right:6px;">Edit</button>
              <button class="cancel-btn" onclick={`removeGuest('${g.id}', '${g.display_name.replace(/'/g, "\\'")}')`}>Remove</button>
            </div>
          ))}
          {guests.map(g => prefsByPerson[g.id] && prefsByPerson[g.id].length > 0 && (
            <div class="guest-prefs" data-guest-id={g.id}>
              <strong>{g.display_name}'s preferences:</strong>
              <ul>
                {prefsByPerson[g.id].map(p => (
                  <li class={`pref-${p.category}`}>
                    <span class="pref-category">{p.category.replace(/_/g, ' ')}</span>: {p.item}
                    {p.detail && <em> — {p.detail}</em>}
                    <button class="pref-remove" onclick={`removeGuestPref('${p.id}')`} title="Remove">&times;</button>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      )}

      <h3>Add a guest</h3>
      <form id="guest-add-form" onsubmit="addGuest(event)">
        <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:flex-end;">
          <label style="flex: 1 1 140px;">
            Name
            <input type="text" name="name" placeholder="Bobby, Aunt Rhonda" required maxlength="30">
          </label>
          <label style="flex: 1 1 140px;">
            Cooking experience
            <select name="experience">
              <option value="novice">Novice</option>
              <option value="beginner" selected>Beginner</option>
              <option value="intermediate">Intermediate</option>
              <option value="experienced">Experienced</option>
              <option value="expert">Expert</option>
            </select>
          </label>
          <label class="checkbox-label" style="flex: 0 1 auto;">
            <input type="checkbox" name="wine_pairing">
            Wine pairings
          </label>
        </div>
        <div style="margin-top:8px;">
          <button type="submit" class="plan-btn">Add guest</button>
          <span id="guest-add-status" class="settings-status"></span>
        </div>
      </form>

      <h3>Add a preference or allergy for a guest</h3>
      {guests.length === 0 ? (
        <p class="settings-hint">Add a guest first.</p>
      ) : (
        <form id="guest-pref-form" onsubmit="addGuestPref(event)">
          <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:flex-end;">
            <label style="flex: 1 1 120px;">
              Person
              <select name="guest_id" required>
                {guests.map(g => <option value={g.id}>{g.display_name}</option>)}
              </select>
            </label>
            <label style="flex: 1 1 140px;">
              Type
              <select name="category">
                <option value="allergy">Allergy (critical)</option>
                <option value="do_not_use">Dislike/avoid</option>
                <option value="use_sparingly">Use sparingly</option>
                <option value="prefer">Prefers</option>
                <option value="general">General note</option>
              </select>
            </label>
            <label style="flex: 1 1 160px;">
              Item
              <input type="text" name="item" placeholder="shellfish, pork, spicy food..." required maxlength="80">
            </label>
          </div>
          <label style="display:block; margin-top:8px;">
            Detail (optional)
            <input type="text" name="detail" placeholder="E.g., 'severe reaction', 'texture issue'" maxlength="200">
          </label>
          <div style="margin-top:8px;">
            <button type="submit" class="plan-btn">Add preference</button>
            <span id="guest-pref-status" class="settings-status"></span>
          </div>
        </form>
      )}
    </div>

    <!-- Account -->
    <div class="settings-section">
      <h2>Account</h2>
      <p>Signed in as <strong>{user.email}</strong></p>
      <p>Tier: <strong>{tier}</strong></p>
      <a href="/subscribe" class="plan-btn" style="display:inline-block; text-decoration:none; text-align:center; margin-bottom: 20px">Manage subscription</a>

      <h3>Your data</h3>
      <p class="settings-hint">
        Your recipes, preferences, pantry, and conversations are private to you and your household. Nobody else can see them, and we don't sell or share your data with anyone. Recipe generation requests go to Anthropic's Claude API (which doesn't retain or train on your data), and payments go through Stripe.
      </p>
      <p>
        <a href="/api/account/export" class="plan-btn" style="display:inline-block; text-decoration:none; text-align:center">Download all my data (JSON)</a>
      </p>

      <h3>Delete account</h3>
      <p class="settings-hint">
        Permanently delete your account and all your data. This cannot be undone.
        {people.length > 1 && ' Your household remains for the other members — your preferences and usage are removed, shared pantry/recipes stay with them.'}
        {people.length === 1 && ' Since you\'re the only member of your household, all household data (pantry, saved recipes, conversations) will be deleted too.'}
      </p>
      <label class="settings-form-label" style="display:block; font-size:0.82rem; margin-top:8px; margin-bottom:4px; color: var(--text-muted);">
        (Optional) Reason for leaving or suggestion to improve:
      </label>
      <textarea id="delete-reason" maxlength="500" rows="2" style="width:100%; padding:6px 10px; border:1px solid var(--border); border-radius:var(--radius-sm); font-family:var(--font); font-size:0.85rem; margin-bottom:8px; box-sizing:border-box;" placeholder="Your honest feedback is appreciated (max 500 chars)"></textarea>
      <br>
      <button class="cancel-btn" onclick="deleteAccount()" style="background: #fef2f2; color: #dc2626; border-color: #fca5a5">Delete my account</button>
    </div>
  </div>

  <script is:inline>
    // Profile save
    document.getElementById('profile-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const status = document.getElementById('profile-status');
      const body = {
        display_name: form.display_name.value.trim() || null,
        experience: form.experience.value,
        wine_pairing: form.wine_pairing.checked,
      };
      try {
        const resp = await fetch('/api/household/profile', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const result = await resp.json();
        status.textContent = result.ok ? 'Saved!' : (result.error || 'Failed');
        status.className = 'settings-status ' + (result.ok ? 'success' : 'error');
        setTimeout(() => status.textContent = '', 2000);
      } catch { status.textContent = 'Network error'; }
    });

    // Invite
    document.getElementById('invite-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const status = document.getElementById('invite-status');
      try {
        const resp = await fetch('/api/household/invite', {
          method: 'POST',
          body: new FormData(form),
        });
        const result = await resp.json();
        if (result.ok) {
          status.textContent = 'Invite sent!';
          status.className = 'settings-status success';
          form.reset();
          setTimeout(() => location.reload(), 1500);
        } else {
          status.textContent = result.error || 'Failed';
          status.className = 'settings-status error';
        }
      } catch { status.textContent = 'Network error'; }
    });

    // Remove member
    window.removeMember = async (id, name) => {
      if (!confirm(`Remove ${name} from the household? They'll be moved to their own household and both of you will be notified.`)) return;
      try {
        const resp = await fetch('/api/household/leave', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ member_id: id }),
        });
        if (resp.ok) location.reload();
        else alert('Failed to remove member.');
      } catch { alert('Network error.'); }
    };

    // Leave household
    window.leaveHousehold = async () => {
      if (!confirm('Leave this household? A new personal household will be created for you. Your preferences and saved recipes will be copied.')) return;
      try {
        const resp = await fetch('/api/household/leave', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({}),
        });
        if (resp.ok) location.reload();
        else alert('Failed to leave household.');
      } catch { alert('Network error.'); }
    };

    // --- Guest management ---

    window.addGuest = async (e) => {
      e.preventDefault();
      const form = e.target;
      const status = document.getElementById('guest-add-status');
      const body = {
        name: form.name.value.trim(),
        experience: form.experience.value,
        wine_pairing: form.wine_pairing.checked,
      };
      try {
        const resp = await fetch('/api/guest', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const result = await resp.json();
        if (result.ok) {
          status.textContent = 'Added!';
          status.className = 'settings-status success';
          form.reset();
          setTimeout(() => location.reload(), 800);
        } else {
          status.textContent = result.error || 'Failed';
          status.className = 'settings-status error';
        }
      } catch { status.textContent = 'Network error'; }
    };

    window.removeGuest = async (id, name) => {
      if (!confirm(`Remove ${name} from your household? Their preferences will be deleted too.`)) return;
      try {
        const resp = await fetch('/api/guest?id=' + id, { method: 'DELETE' });
        if (resp.ok) location.reload();
      } catch { alert('Network error'); }
    };

    window.editGuest = async (id, name, experience, winePairing) => {
      const newName = prompt('Name:', name);
      if (!newName || newName.trim() === name) return;
      try {
        const resp = await fetch('/api/guest?id=' + id, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ display_name: newName.trim() }),
        });
        if (resp.ok) location.reload();
      } catch { alert('Network error'); }
    };

    window.addGuestPref = async (e) => {
      e.preventDefault();
      const form = e.target;
      const status = document.getElementById('guest-pref-status');
      const body = {
        guest_id: form.guest_id.value,
        category: form.category.value,
        item: form.item.value.trim(),
        detail: form.detail.value.trim() || null,
      };
      try {
        const resp = await fetch('/api/guest/preference', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const result = await resp.json();
        if (result.ok) {
          status.textContent = 'Added!';
          status.className = 'settings-status success';
          form.reset();
          setTimeout(() => location.reload(), 800);
        } else {
          status.textContent = result.error || 'Failed';
          status.className = 'settings-status error';
        }
      } catch { status.textContent = 'Network error'; }
    };

    window.removeGuestPref = async (id) => {
      if (!confirm('Remove this preference?')) return;
      try {
        const resp = await fetch('/api/guest/preference?id=' + id, { method: 'DELETE' });
        if (resp.ok) location.reload();
      } catch { alert('Network error'); }
    };

    // Account deletion — two-step confirmation, with optional feedback
    window.deleteAccount = async () => {
      const first = confirm(
        'Permanently delete your account?\n\n' +
        '• Your profile, preferences, usage history, and any active subscription will be deleted.\n' +
        '• If you are the last member of your household, all shared data (pantry, saved recipes, conversations) will also be deleted.\n' +
        '• This action CANNOT be undone.\n\n' +
        'Consider downloading your data first. Continue?'
      );
      if (!first) return;

      const typed = prompt('Type DELETE (all caps) to confirm account deletion:');
      if (typed !== 'DELETE') {
        alert('Deletion cancelled.');
        return;
      }

      // Send reason/suggestion first (if provided), before the account
      // goes away — the message endpoint records user_email independently.
      const reason = document.getElementById('delete-reason')?.value?.trim();
      if (reason) {
        try {
          await fetch('/api/message', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ context: 'deletion', message: reason }),
          });
        } catch {} // non-blocking
      }

      try {
        const resp = await fetch('/api/account/delete', { method: 'DELETE' });
        const result = await resp.json();
        if (result.ok) {
          alert('Your account has been deleted. Thank you for using Recipe Wizard.');
          window.location.href = '/';
        } else {
          alert('Failed to delete account: ' + (result.error || 'Unknown error'));
        }
      } catch (err) {
        alert('Network error. Please try again.');
      }
    };

    // Respond to invite notification
    window.respondInvite = async (inviteId, action, notifId) => {
      try {
        const resp = await fetch('/api/household/respond', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ invite_id: inviteId, action, carry_pantry: [] }),
        });
        if (resp.ok) {
          // Mark notification as read
          await fetch('/api/household/profile', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ mark_notification_read: notifId }),
          });
          location.reload();
        }
      } catch { alert('Network error.'); }
    };
  </script>
</body>
</html>
